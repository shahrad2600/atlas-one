# ─────────────────────────────────────────────────────────────
# Atlas One — Environment Configuration
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────

# ── Node ──────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug

# ── PostgreSQL ────────────────────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=atlas_dev
DATABASE_USER=atlas
DATABASE_PASSWORD=atlas_secret
DATABASE_URL=postgresql://atlas:atlas_secret@localhost:5432/atlas_dev?sslmode=disable
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379
REDIS_TLS_ENABLED=false

# ── Kafka (optional) ─────────────────────────────────────────
KAFKA_ENABLED=false
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=atlas-one
KAFKA_GROUP_ID=atlas-consumer-group

# ── Authentication / JWT ──────────────────────────────────────
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_EXPIRES_IN=7d
JWT_ISSUER=atlas-one

# ── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXX
STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXX

# ── AI / LLM Model API Keys ──────────────────────────────────
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXX
OPENAI_ORG_ID=
OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXX
ANTHROPIC_MODEL=claude-sonnet-4-20250514

GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemini-2.0-flash

# ── Embeddings / Vector Search ────────────────────────────────
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ── Email (SMTP) ──────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@atlas.local

# ── Object Storage / S3 ──────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=atlas-uploads
S3_REGION=us-east-1

# ── App Ports ────────────────────────────────────────────────
PORT_WEB=3000
PORT_ADMIN=3001
PORT_CONCIERGE=3002

# ── Service Ports ─────────────────────────────────────────────
PORT_IDENTITY=4001
PORT_TRAVEL_GRAPH=4002
PORT_SEARCH=4003
PORT_TRIP=4004
PORT_COMMERCE=4005
PORT_DINING=4006
PORT_EXPERIENCES=4007
PORT_STAY=4008
PORT_FLIGHT=4009
PORT_INSURANCE=4010
PORT_FINANCE=4011
PORT_LUXURY=4012
PORT_MESSAGING=4013
PORT_TRUST=4014
PORT_AI_ORCHESTRATOR=4015
PORT_RENTAL=4020
PORT_CRUISE=4021

# ── Observability ─────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=atlas-one
SENTRY_DSN=

# ── Feature Flags ─────────────────────────────────────────────
FEATURE_AI_CONCIERGE=true
FEATURE_DYNAMIC_PRICING=false
FEATURE_MULTI_CURRENCY=false

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
