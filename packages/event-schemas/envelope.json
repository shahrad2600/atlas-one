{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AtlasEventEnvelope",
  "description": "Common envelope for all Atlas One platform events",
  "type": "object",
  "required": ["event_id", "event_type", "schema_version", "occurred_at", "producer", "payload"],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this event instance"
    },
    "event_type": {
      "type": "string",
      "pattern": "^[a-z]+\\.[a-z_]+\\.[a-z_]+$",
      "description": "Dot-separated event type in the form domain.entity.action"
    },
    "schema_version": {
      "type": "integer",
      "minimum": 1,
      "description": "Schema version for forward/backward compatibility"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the event occurred"
    },
    "producer": {
      "type": "string",
      "description": "Identifier of the service that produced this event"
    },
    "trace_id": {
      "type": "string",
      "description": "Distributed tracing identifier for observability"
    },
    "correlation_id": {
      "type": "string",
      "description": "Identifier linking related events across services"
    },
    "tenant_id": {
      "type": ["string", "null"],
      "format": "uuid",
      "description": "Tenant identifier for multi-tenant isolation"
    },
    "actor": {
      "type": "object",
      "description": "The entity that triggered this event",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["user", "system", "agent", "partner"]
        },
        "id": {
          "type": "string"
        }
      }
    },
    "payload": {
      "type": "object",
      "description": "Event-specific payload data"
    }
  }
}
