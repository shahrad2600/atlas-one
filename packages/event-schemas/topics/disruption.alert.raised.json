{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "disruption.alert.raised",
  "description": "Emitted when a travel disruption is detected that may affect trips or reservations",
  "allOf": [{ "$ref": "../envelope.json" }],
  "properties": {
    "payload": {
      "type": "object",
      "required": ["disruption_id", "disruption_type", "severity", "affected_dates", "location", "recommended_actions", "evidence"],
      "properties": {
        "disruption_id": {
          "type": "string",
          "format": "uuid",
          "description": "Unique identifier for the disruption"
        },
        "trip_id": {
          "type": ["string", "null"],
          "format": "uuid",
          "description": "Affected trip, if identified"
        },
        "reservation_id": {
          "type": ["string", "null"],
          "format": "uuid",
          "description": "Affected reservation, if identified"
        },
        "ticket_id": {
          "type": ["string", "null"],
          "format": "uuid",
          "description": "Affected support ticket, if applicable"
        },
        "disruption_type": {
          "type": "string",
          "enum": [
            "weather",
            "strike",
            "closure",
            "delay",
            "cancellation",
            "diversion",
            "natural_disaster",
            "civil_unrest",
            "health_advisory"
          ],
          "description": "Category of the disruption"
        },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"],
          "description": "Impact severity level"
        },
        "affected_dates": {
          "type": "array",
          "description": "Dates affected by the disruption",
          "items": {
            "type": "string",
            "format": "date"
          }
        },
        "location": {
          "type": "object",
          "description": "Geographic location of the disruption",
          "required": ["place_id", "name", "lat", "lng"],
          "properties": {
            "place_id": {
              "type": "string",
              "format": "uuid",
              "description": "Travel Graph place identifier"
            },
            "name": {
              "type": "string",
              "description": "Human-readable location name"
            },
            "lat": {
              "type": "number",
              "minimum": -90,
              "maximum": 90,
              "description": "Latitude"
            },
            "lng": {
              "type": "number",
              "minimum": -180,
              "maximum": 180,
              "description": "Longitude"
            }
          }
        },
        "recommended_actions": {
          "type": "array",
          "description": "Suggested actions to mitigate the disruption",
          "items": {
            "type": "string",
            "enum": ["rebook", "refund", "reroute", "wait", "hotel", "meal_voucher"]
          }
        },
        "evidence": {
          "type": "object",
          "description": "Supporting evidence for the disruption alert",
          "properties": {
            "source": {
              "type": "string",
              "description": "Data source for the disruption (e.g., airline API, weather service)"
            },
            "details": {
              "type": "string",
              "description": "Human-readable description of the disruption evidence"
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Confidence score in the disruption assessment (0-1)"
            }
          }
        }
      }
    }
  }
}
