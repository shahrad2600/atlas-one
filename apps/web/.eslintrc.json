{
  "extends": "next/core-web-vitals",
  "rules": {
    "import/no-unresolved": "off",
    "import/no-cycle": "off",
    "import/namespace": "off",
    "import/order": "off",
    "import/no-duplicates": "off",
    "import/no-self-import": "off",
