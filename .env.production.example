###############################################################################
# Atlas One — Production Environment Variables
# Copy to .env.production and fill in real values before deploying.
# NEVER commit the actual .env.production file to version control.
###############################################################################

# ── Node ───────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── PostgreSQL ─────────────────────────────────────────────────────────────
DATABASE_NAME=atlas_prod
DATABASE_USER=atlas
DATABASE_PASSWORD=CHANGE_ME_strong_password_here
DATABASE_URL=postgresql://atlas:CHANGE_ME_strong_password_here@postgres:5432/atlas_prod?sslmode=disable

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password_here
REDIS_URL=redis://:CHANGE_ME_redis_password_here@redis:6379

# ── JWT / Auth ─────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_minimum_64_character_random_string
JWT_REFRESH_SECRET=CHANGE_ME_another_64_character_random_string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── CORS ───────────────────────────────────────────────────────────────────
CORS_ORIGIN=https://sarve.com

# ── Domain / URLs ──────────────────────────────────────────────────────────
SITE_URL=https://sarve.com
ADMIN_URL=https://admin.sarve.com
CONCIERGE_URL=https://concierge.sarve.com
API_URL=https://api.sarve.com

# ── Stripe (Payments) ─────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ── AI / LLM ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-CHANGE_ME
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# ── Email (SMTP) ──────────────────────────────────────────────────────────
SMTP_HOST=smtp.ionos.com
SMTP_PORT=587
SMTP_USER=noreply@sarve.com
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM=Atlas One <noreply@sarve.com>

# ── Object Storage (S3-compatible) ────────────────────────────────────────
S3_BUCKET=atlas-prod-assets
S3_REGION=us-east-1
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_ENDPOINT=https://s3.amazonaws.com

# ── Google OAuth (Social Sign-In) ─────────────────────────────────────────
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME

# ── Apple Sign-In ─────────────────────────────────────────────────────────
APPLE_CLIENT_ID=com.sarve.web
APPLE_TEAM_ID=CHANGE_ME
APPLE_KEY_ID=CHANGE_ME
APPLE_PRIVATE_KEY_PATH=/run/secrets/apple_auth_key

# ── SSL / Let's Encrypt ───────────────────────────────────────────────────
CERTBOT_EMAIL=admin@sarve.com

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json

# ── Sentry (Error Tracking) ───────────────────────────────────────────────
SENTRY_DSN=https://CHANGE_ME@o0.ingest.sentry.io/0
SENTRY_ENVIRONMENT=production

# ── Analytics ──────────────────────────────────────────────────────────────
GA_MEASUREMENT_ID=G-CHANGE_ME
